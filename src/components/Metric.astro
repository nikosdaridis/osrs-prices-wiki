---
interface Props {
  id: string;
  label: string;
  title?: string;
  emphasis?: boolean;
}

const { id, label, title, emphasis = false } = Astro.props;
---

<div
  class="group relative flex flex-col gap-0.5 select-none"
  title={title}
  data-metric-id={id}
>
  <svg
    class="pointer-events-none absolute top-0 right-0 text-muted opacity-0 transition-opacity group-hover:opacity-50"
    width="6"
    height="10"
    viewBox="0 0 6 10"
    fill="currentColor"
    aria-hidden="true"
  >
    <circle cx="1.5" cy="1.5" r="0.9"></circle>
    <circle cx="4.5" cy="1.5" r="0.9"></circle>
    <circle cx="1.5" cy="5" r="0.9"></circle>
    <circle cx="4.5" cy="5" r="0.9"></circle>
    <circle cx="1.5" cy="8.5" r="0.9"></circle>
    <circle cx="4.5" cy="8.5" r="0.9"></circle>
  </svg>
  <span class="pr-3 text-[11px] tracking-wider text-muted-foreground uppercase">
    {label}
  </span>
  <span
    id={id}
    class:list={[
      "text-fg tabular-nums",
      emphasis ? "text-[17px] font-medium" : "text-[15px]",
    ]}>—</span
  >
</div>
