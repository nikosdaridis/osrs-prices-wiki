---
import GitHubLink from "./GitHubLink.astro";
import PageSizePopover from "./PageSizePopover.astro";
---

<div
  id="pagination-bar"
  class="flex min-h-9 shrink-0 flex-wrap items-center justify-center gap-x-3 gap-y-1 border-t border-border bg-bg px-4 py-1 text-[13px] text-muted sm:h-9 sm:flex-nowrap sm:justify-between sm:gap-y-0 sm:py-0"
>
  <div class="hidden flex-1 items-center sm:flex">
    <span
      class="flex items-center gap-1 text-muted tabular-nums"
      title="Time until next data refresh"
    >
      <svg
        viewBox="0 0 24 24"
        width="12"
        height="12"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
        <path d="M21 3v5h-5"></path>
        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
        <path d="M8 16H3v5"></path>
      </svg>
      <span id="refresh-countdown" class="text-fg">…</span>
    </span>
  </div>

  <div
    class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 sm:flex-nowrap sm:gap-y-0"
  >
    <PageSizePopover />

    <div class="hidden h-4 w-px bg-border sm:block"></div>

    <div class="flex items-center gap-1">
      <button
        id="page-first"
        type="button"
        aria-label="First page"
        title="First page"
        class="grid h-7 w-7 place-items-center rounded border border-border bg-surface text-fg hover:border-accent disabled:opacity-40 disabled:hover:border-border"
      >
        <svg
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m11 17-5-5 5-5"></path>
          <path d="m18 17-5-5 5-5"></path>
        </svg>
      </button>
      <button
        id="page-prev"
        type="button"
        aria-label="Previous page"
        title="Previous page"
        class="grid h-7 w-7 place-items-center rounded border border-border bg-surface text-fg hover:border-accent disabled:opacity-40 disabled:hover:border-border"
      >
        <svg
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
      </button>
      <span id="page-indicator" class="px-2 text-fg tabular-nums"
        >Page 0 / 0</span
      >
      <button
        id="page-next"
        type="button"
        aria-label="Next page"
        title="Next page"
        class="grid h-7 w-7 place-items-center rounded border border-border bg-surface text-fg hover:border-accent disabled:opacity-40 disabled:hover:border-border"
      >
        <svg
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </button>
      <button
        id="page-last"
        type="button"
        aria-label="Last page"
        title="Last page"
        class="grid h-7 w-7 place-items-center rounded border border-border bg-surface text-fg hover:border-accent disabled:opacity-40 disabled:hover:border-border"
      >
        <svg
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m13 17 5-5-5-5"></path>
          <path d="m6 17 5-5-5-5"></path>
        </svg>
      </button>
    </div>

    <div class="hidden h-4 w-px bg-border sm:block"></div>

    <span class="hidden tabular-nums sm:inline">
      <span id="visible-count" class="text-fg">0</span> items
    </span>
  </div>

  <div class="hidden items-center gap-3 sm:flex sm:flex-1 sm:justify-end">
    <GitHubLink />
    <span class="hidden h-3 w-px bg-border lg:block"></span>
    <span class="hidden whitespace-nowrap lg:inline"
      >Not affiliated with Jagex</span
    >
  </div>
</div>

<script>
  import {
    paginationFirst,
    paginationLast,
    paginationNext,
    paginationPrev,
  } from "../scripts/grid";

  const indicator = document.getElementById("page-indicator");
  const countElement = document.getElementById("visible-count");
  const firstButton = document.getElementById("page-first");
  const previousButton = document.getElementById("page-prev");
  const nextButton = document.getElementById("page-next");
  const lastButton = document.getElementById("page-last");

  if (
    indicator !== null &&
    countElement !== null &&
    firstButton instanceof HTMLButtonElement &&
    previousButton instanceof HTMLButtonElement &&
    nextButton instanceof HTMLButtonElement &&
    lastButton instanceof HTMLButtonElement
  ) {
    firstButton.addEventListener("click", () => paginationFirst());
    previousButton.addEventListener("click", () => paginationPrev());
    nextButton.addEventListener("click", () => paginationNext());
    lastButton.addEventListener("click", () => paginationLast());

    window.addEventListener("pagination:change", (event) => {
      const { currentPage, totalPages, rowCount } = event.detail;
      const displayPage = totalPages === 0 ? 0 : currentPage + 1;
      indicator.textContent = `Page ${displayPage} / ${totalPages}`;
      countElement.textContent = rowCount.toLocaleString("en-US");

      const onFirstPage = totalPages === 0 || currentPage <= 0;
      const onLastPage = totalPages === 0 || currentPage >= totalPages - 1;
      firstButton.disabled = onFirstPage;
      previousButton.disabled = onFirstPage;
      nextButton.disabled = onLastPage;
      lastButton.disabled = onLastPage;
    });
  }
</script>
